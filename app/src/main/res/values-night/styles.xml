<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">22sp</item>
        <item name="fontFamily">@font/ys_display_medium</item>
        <item name="android:textColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>
    <style name="MainButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/YPblack</item>
        <item name="android:textSize">@dimen/big_text</item>
        <item name="cornerRadius">@dimen/corner_radius_buttons</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@color/YPblack</item>
        <item name="fontFamily">@font/ys_display_medium</item>
    </style>
    <style name="SettingsVariant">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="drawableTint">@color/white</item>
        <item name="android:textSize">@dimen/small_text</item>
        <item name="android:textColor">@color/white</item>
        <item name="fontFamily">@font/ys_display_regular</item>
    </style>
    <style name="MainScreenDayNight">
        <item name="android:background">@color/YPblack</item>
    </style>
    <style name="EditTextSearch">
        <item name="android:drawableTint">@color/YPblack</item>
        <item name="android:textColorHint">@color/YPblack</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:textColor">@color/YPblack</item>
    </style>
    <style name="TrackCardNameTrack">
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="TrackCardNameBandAndTime">
        <item name="android:textColor">@color/white</item>
        <item name="drawableTint">@color/white</item>
    </style>
    <style name="BackgroundSearchAct">
        <item name="android:background">@color/YPblack</item>
    </style>
</resources>


