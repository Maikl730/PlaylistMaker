<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:gravity="start"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/track_image"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center_vertical"/>

        <LinearLayout
            android:paddingLeft="8dp"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/track_name"
                style="@style/TrackCardNameTrack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smells Like Teen Spirit"
                android:textSize="@dimen/small_text"
                android:fontFamily="@font/ys_display_regular"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
            <TextView
                android:id="@+id/track_band"
                style="@style/TrackCardNameBandAndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLength="40"
                android:maxLines="1"
                android:text="Nirvana"
                android:drawableEnd="@drawable/point"
                android:textSize="@dimen/smallest_text"
                android:fontFamily="@font/ys_display_regular"/>

                <TextView
                    android:id="@+id/track_long"
                    style="@style/TrackCardNameBandAndTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5:01"
                    android:textSize="11dp"
                    android:fontFamily="@font/ys_display_regular"/>

            </LinearLayout>

        </LinearLayout>
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical">
        <TextView
            android:id="@+id/track_about_button"
            style="@style/TrackCardNameBandAndTime"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:paddingEnd="4dp"
            android:drawableEnd="@drawable/arrow_forward"
            android:layout_gravity="end"
            />
        </FrameLayout>

    </LinearLayout>






</FrameLayout>